generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  completed
  cancelled
  refunded
}

enum PaymentType {
  charge
  refund
}

enum PaymentStatus {
  settled
  pending
  failed
}

enum ReconciliationStatus {
  EXACT_MATCH
  MISSING_ORDER
  MISSING_PAYMENT
  AMOUNT_MISMATCH
  PARTIAL_REFUND
  PENDING_PAYMENT
  FAILED_PAYMENT
}

model User {
  id                    String                 @id @default(cuid())
  email                 String                 @unique
  passwordHash          String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  orders                Order[]
  payments              Payment[]
  reconciliationResults ReconciliationResult[]
}

model Order {
  id                    String                 @id @default(cuid())
  userId                String
  orderId               String
  normalizedOrderId     String
  orderDate             DateTime
  customerEmail         String?
  currency              String
  grossAmount           Decimal                @db.Decimal(12, 2)
  discount              Decimal                @db.Decimal(12, 2)
  netAmount             Decimal                @db.Decimal(12, 2)
  status                OrderStatus
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  reconciliationResults ReconciliationResult[]

  @@unique([userId, normalizedOrderId])
  @@index([userId, status])
  @@index([userId, normalizedOrderId])
}

model Payment {
  id                    String                 @id @default(cuid())
  userId                String
  transactionRef        String
  processedAt           DateTime?
  orderReference        String
  normalizedOrderId     String
  currency              String
  amount                Decimal                @db.Decimal(12, 2)
  fee                   Decimal                @db.Decimal(12, 2)
  netSettled            Decimal                @db.Decimal(12, 2)
  type                  PaymentType
  status                PaymentStatus
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  reconciliationResults ReconciliationResult[]

  @@unique([userId, transactionRef])
  @@index([userId, normalizedOrderId])
  @@index([userId, status, type])
}

model ReconciliationResult {
  id                String               @id @default(cuid())
  userId            String
  orderId           String?
  paymentId         String?
  normalizedOrderId String
  status            ReconciliationStatus
  expectedAmount    Decimal?             @db.Decimal(12, 2)
  actualAmount      Decimal?             @db.Decimal(12, 2)
  difference        Decimal?             @db.Decimal(12, 2)
  currency          String?
  details           Json
  createdAt         DateTime             @default(now())
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  order             Order?               @relation(fields: [orderId], references: [id], onDelete: SetNull)
  payment           Payment?             @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([userId, normalizedOrderId])
}
